# ─── Language Configuration ───────────────────────────────────────────────────
# Comma-separated list of enabled locale codes.
# The FIRST locale is the default (served at / with no prefix).
# To disable a language: remove it from this list.
# To add a language: add the code here AND create the JSON data files.
NEXT_PUBLIC_ENABLED_LOCALES=it,en,ur

# ─── Site / Domain Mapping ────────────────────────────────────────────────────
# hostname:siteKey pairs, comma-separated.
# siteKey must match a folder under /src/data/
SITE_DOMAIN_MAP=javedgroup.local:group,agenzia.javedgroup.local:agenzia,assicurazioni.javedgroup.local:assicurazioni,kiwi.javedgroup.local:kiwi,viaggi.javedgroup.local:viaggi,javedgroup.com:group,agenzia.javedgroup.com:agenzia,assicurazioni.javedgroup.com:assicurazioni,kiwi.javedgroup.com:kiwi,viaggi.javedgroup.com:viaggi

# ─── Base URLs ────────────────────────────────────────────────────────────────
BASE_URL_GROUP=https://javedgroup.com
BASE_URL_AGENZIA=https://agenzia.javedgroup.com
BASE_URL_ASSICURAZIONI=https://assicurazioni.javedgroup.com
BASE_URL_KIWI=https://kiwi.javedgroup.com
BASE_URL_VIAGGI=https://viaggi.javedgroup.com
